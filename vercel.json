{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://lurk-rounding-tidiness.ngrok-free.dev/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://lurk-rounding-tidiness.ngrok-free.dev/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}

VITE_CONTACT_EMAIL=your@email.com
VITE_INSTAGRAM_HANDLE=@yourhandle
VITE_INSTAGRAM_URL=https://instagram.com/yourhandle
VITE_SITE_URL=https://yourdomain.com
# Base path catalogo Work (default /api). In Docker nginx fa da gateway verso i microservizi.
VITE_MEDIA_API_BASE=/api
# Timeout (ms) per le fetch parallele foto+video; oltre si resta sui dati statici.
# VITE_MEDIA_API_TIMEOUT_MS=12000

# API auth admin (microservizio auth-service): login, logout, sessione
# VITE_AUTH_API_BASE=/api/auth
# Editor di default (dopo migrate DB): editor@assezero.local / editor_dev_change_me

# Se avvii photo-service / video-service in locale mentre MySQL gira in Docker (porta 3306 esposta):
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=assezero
# MYSQL_PASSWORD=appsecret
# (photo-service usa MYSQL_DATABASE=photos_svc, video-service videos_svc — impostali nel comando o in .env del servizio)

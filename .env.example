# ════════════════════════════════════════════════════════════════
# ASSE ZERO — Variabili d'ambiente
# ════════════════════════════════════════════════════════════════
# 1. Copia questo file: cp .env.example .env
# 2. Compila TUTTI i valori segnati con (RICHIESTO)
# 3. NON committare mai il file .env su Git (è già in .gitignore)
# ════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────
# FRONTEND — Dati pubblici del sito (vite li injecta nel bundle)
# Questi valori NON sono segreti: finiranno nel codice JavaScript
# ────────────────────────────────────────────────────────────────
VITE_CONTACT_EMAIL=your@email.com                        # (RICHIESTO)
VITE_INSTAGRAM_HANDLE=@yourhandle                        # (RICHIESTO)
VITE_INSTAGRAM_URL=https://instagram.com/yourhandle      # (RICHIESTO)
VITE_SITE_URL=https://yourdomain.com                     # (RICHIESTO)

# Path base per le API multimediali (non cambiare in produzione Docker)
VITE_MEDIA_API_BASE=/api

# ────────────────────────────────────────────────────────────────
# DATABASE MYSQL — Credenziali (SEGRETI)
# ────────────────────────────────────────────────────────────────

# Password dell'utente root di MySQL (usata solo internamente da Docker)
# Genera con: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=change_me_root_password              # (RICHIESTO)

# Utente applicativo MySQL (usato dai microservizi per connettersi al DB)
MYSQL_USER=assezero
MYSQL_PASSWORD=change_me_db_password                     # (RICHIESTO) Min. 20 caratteri

# ────────────────────────────────────────────────────────────────
# JWT — Chiave segreta per la firma dei token (SEGRETO CRITICO)
# ────────────────────────────────────────────────────────────────
# IMPORTANTE: deve essere una stringa casuale lunga almeno 64 caratteri.
# Chiunque conosca questo valore può firmare token validi come qualsiasi utente.
# Genera con: openssl rand -base64 64
JWT_SECRET=change_me_with_a_long_random_secret_min_64_chars  # (RICHIESTO)

# Durata del token di sessione admin (es. 8h, 1d, 7d)
JWT_EXPIRES_IN=8h

# ────────────────────────────────────────────────────────────────
# ACCOUNT ADMIN — Credenziali iniziali per il primo avvio
# Vengono usate solo se gli account non esistono già nel DB
# ────────────────────────────────────────────────────────────────
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com                 # (RICHIESTO)
DEFAULT_ADMIN_PASSWORD=change_me_admin_password          # (RICHIESTO) Min. 16 caratteri

DEFAULT_EDITOR_EMAIL=editor@yourdomain.com               # (RICHIESTO)
DEFAULT_EDITOR_PASSWORD=change_me_editor_password        # (RICHIESTO) Min. 16 caratteri

# ════════════════════════════════════════════════════════════════
# SVILUPPO LOCALE (senza Docker) 
# ════════════════════════════════════════════════════════════════
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# (photo-service usa MYSQL_DATABASE=photos_svc)
# (video-service usa MYSQL_DATABASE=videos_svc)
# (auth-service  usa MYSQL_DATABASE=auth_svc)
